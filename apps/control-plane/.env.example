NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
JWT_SECRET=replace-me
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/apployd?schema=public
# Use a direct/non-pooler Postgres URL for Prisma migrate commands (required for Neon/Supabase poolers).
DIRECT_DATABASE_URL=postgresql://db_user:db_password@localhost:5432/apployd?schema=public
REDIS_URL=redis://localhost:6379
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=replace
SMTP_FROM_EMAIL=notifications@apployd.com
SMTP_FROM_NAME=Apployd
# Optional. Leave empty to allow inviting any email domain.
# Example to restrict: INVITE_ALLOWED_EMAIL_DOMAINS=company.com,partner.io
INVITE_ALLOWED_EMAIL_DOMAINS=
INVITE_WEBHOOK_TOKEN=replace
INVITE_REMINDER_ENABLED=true
INVITE_REMINDER_DELAY_HOURS=24
INVITE_REMINDER_INTERVAL_HOURS=24
INVITE_MAX_REMINDERS=2
INVITE_MAINTENANCE_INTERVAL_SECONDS=300
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/integrations/github/callback
GITHUB_WEBHOOK_SECRET=
# Optional fallback token used for Vercel migration import if user does not provide one.
VERCEL_ACCESS_TOKEN=
DASHBOARD_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
PLATFORM_ADMIN_EMAILS=ops@apployd.com
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
METRICS_AUTH_TOKEN=
CLOUDFLARE_API_TOKEN=replace
CLOUDFLARE_ZONE_ID=replace
BASE_DOMAIN=localhost
PREVIEW_BASE_DOMAIN=localhost
PREVIEW_DOMAIN_STYLE=project
DEFAULT_REGION=fsn1
ALLOW_RISKY_DEPLOYMENT_COMMANDS=false
AUTO_PROVISION_DEV_SERVER=true
DEV_SERVER_NAME=local-dev-1
DEV_SERVER_IPV4=127.0.0.1
DEV_SERVER_TOTAL_RAM_MB=8192
DEV_SERVER_TOTAL_CPU_MILLICORES=4000
DEV_SERVER_TOTAL_BANDWIDTH_GB=1000
EDGE_WAKE_TOKEN=
