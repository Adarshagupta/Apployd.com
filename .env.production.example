# Control plane
NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.apployd.com
JWT_SECRET=replace-with-64-char-random-string
DATABASE_URL=postgresql://db_user:db_password@db-host:5432/apployd?sslmode=require
REDIS_URL=redis://redis:6379
DODO_PAYMENTS_API_KEY=dodo_live_replace
DODO_PAYMENTS_WEBHOOK_SECRET=whsec_replace
DODO_PAYMENTS_ENVIRONMENT=live
DODO_PAYMENTS_DEFAULT_COUNTRY=US
DODO_PAYMENTS_PRODUCT_ID_DEV=prod_dev_replace
DODO_PAYMENTS_PRODUCT_ID_PRO=prod_pro_replace
DODO_PAYMENTS_PRODUCT_ID_MAX=prod_max_replace
DODO_PAYMENTS_PRODUCT_ID_AGENT_STARTER=prod_agent_starter_replace
DODO_PAYMENTS_PRODUCT_ID_AGENT_GROWTH=prod_agent_growth_replace
DODO_PAYMENTS_PRODUCT_ID_AGENT_SCALE=prod_agent_scale_replace
DODO_PAYMENTS_ADDON_ID_DATABASE_STARTER=adn_starter_replace
DODO_PAYMENTS_ADDON_ID_DATABASE_GROWTH=adn_growth_replace
DODO_PAYMENTS_ADDON_ID_DATABASE_SCALE=adn_scale_replace
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=replace
SMTP_FROM_EMAIL=notifications@apployd.com
SMTP_FROM_NAME=Apployd
# Optional. Leave empty to allow inviting any email domain.
# Example to restrict: INVITE_ALLOWED_EMAIL_DOMAINS=company.com,partner.io
INVITE_ALLOWED_EMAIL_DOMAINS=
INVITE_WEBHOOK_TOKEN=replace-with-random-secret
INVITE_REMINDER_ENABLED=true
INVITE_REMINDER_DELAY_HOURS=24
INVITE_REMINDER_INTERVAL_HOURS=24
INVITE_MAX_REMINDERS=2
INVITE_MAINTENANCE_INTERVAL_SECONDS=300
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
GITHUB_CLIENT_ID=replace
GITHUB_CLIENT_SECRET=replace
GITHUB_OAUTH_REDIRECT_URI=https://api.apployd.com/api/v1/integrations/github/callback
GOOGLE_CLIENT_ID=replace
GOOGLE_CLIENT_SECRET=replace
GOOGLE_OAUTH_REDIRECT_URI=https://api.apployd.com/api/v1/auth/google/callback
GITHUB_WEBHOOK_SECRET=replace
# Vercel OAuth app credentials (required for Connect Vercel flow).
VERCEL_CLIENT_ID=replace
VERCEL_CLIENT_SECRET=replace
VERCEL_OAUTH_REDIRECT_URI=https://api.apployd.com/api/v1/integrations/vercel/callback
# Optional legacy fallback token for server-side scripts only.
VERCEL_ACCESS_TOKEN=
# Neon API credentials for managed PostgreSQL provisioning.
NEON_API_KEY=replace
NEON_API_BASE_URL=https://console.neon.tech/api/v2
NEON_DEFAULT_REGION=aws-us-east-1
DASHBOARD_BASE_URL=https://apployd.com
CORS_ALLOWED_ORIGINS=https://apployd.com,https://www.apployd.com
PLATFORM_ADMIN_EMAILS=ops@apployd.com
ENCRYPTION_KEY=replace-with-64-char-hex
METRICS_AUTH_TOKEN=replace-with-random-secret
EDGE_WAKE_TOKEN=replace-with-64-char-hex
EDGE_WAKE_RETRY_SECONDS=5
OPENAI_API_KEY=sk_replace
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CODEX_MODEL=gpt-5.2-codex
CLOUDFLARE_API_TOKEN=replace
CLOUDFLARE_ZONE_ID=replace
BASE_DOMAIN=apployd.com
PREVIEW_BASE_DOMAIN=apployd.com
ENGINE_PUBLIC_IPV4=your.public.ip.here
PREVIEW_DOMAIN_STYLE=project
DEFAULT_REGION=fsn1
ALLOW_RISKY_DEPLOYMENT_COMMANDS=false
AUTO_PROVISION_DEV_SERVER=false

# Deployment engine
DASHBOARD_BASE_URL=https://apployd.com
NGINX_SITES_PATH=/etc/nginx/sites-enabled
NGINX_TEMPLATE_PATH=/opt/apployd/nginx/templates/project.conf.tpl
CERTBOT_EMAIL=ops@apployd.com
CONTROL_PLANE_INTERNAL_URL=http://127.0.0.1:4000
EDGE_WAKE_TOKEN=replace-with-64-char-hex
EDGE_WAKE_ENABLED=true
ENGINE_REGION=fsn1
ENGINE_METRICS_PORT=9102
ENGINE_HEALTHCHECK_TIMEOUT_SECONDS=60
ENGINE_HEALTHCHECK_DELAY_MS=1000
ENGINE_LOCAL_MODE=false
ENGINE_CONTAINER_READ_ONLY=true
ENGINE_SECURITY_MODE=strict
ENGINE_SECURITY_AUTO_BLOCK=true
ENGINE_SECURITY_ALLOW_PRIVATE_EGRESS=true
ENGINE_EGRESS_ALLOWED_TCP_PORTS=80,443
ENGINE_EGRESS_ALLOWED_UDP_PORTS=53,123
ENGINE_EGRESS_BLOCKED_TCP_PORTS=21,22,23,25,69,445,1433,3306,3389,5432,6379,8080,11211
ENGINE_EGRESS_BLOCKED_UDP_PORTS=19,161
ENGINE_SECURITY_MAX_DISTINCT_REMOTE_PORTS=8
ENGINE_SECURITY_MAX_DISTINCT_REMOTE_HOSTS=80
ENGINE_SECURITY_MAX_SYN_SENT_CONNECTIONS=30

# Neon API credentials for managed PostgreSQL provisioning.
